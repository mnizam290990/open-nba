# =============================================================================
# openNBA — .gitignore
# Covers: Node.js, Python, React/Next.js, Docker, Terraform, Kubernetes, OS
# =============================================================================

# -----------------------------------------------------------------------------
# Environment & Secrets (NEVER commit these)
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
*.crt
secrets/
**/secrets/

# -----------------------------------------------------------------------------
# Node.js / npm / pnpm / yarn
# -----------------------------------------------------------------------------
node_modules/
.pnp
.pnp.js
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.npm

# -----------------------------------------------------------------------------
# Next.js / React Build Outputs
# -----------------------------------------------------------------------------
.next/
out/
build/
dist/
.vercel

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd
.Python
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml
htmlcov/
*.egg-info/
dist/
build/
*.egg
.eggs/
.tox/
.hypothesis/
.pdm-build/
pdm.lock
*.so

# -----------------------------------------------------------------------------
# Jupyter Notebooks
# -----------------------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb_checkpoints

# -----------------------------------------------------------------------------
# Terraform / Infrastructure
# -----------------------------------------------------------------------------
**/.terraform/
**/.terraform.lock.hcl
*.tfstate
*.tfstate.*
*.tfplan
*.tfvars
!*.tfvars.example
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
.docker/

# -----------------------------------------------------------------------------
# Kubernetes / Helm
# -----------------------------------------------------------------------------
*.kubeconfig
kubeconfig
helm/*/charts/
helm/*/tmpcharts/

# -----------------------------------------------------------------------------
# Databases & Local Data
# -----------------------------------------------------------------------------
*.sqlite
*.sqlite3
*.db
postgres-data/
pgdata/
weaviate-data/

# -----------------------------------------------------------------------------
# Logs & Debugging
# -----------------------------------------------------------------------------
logs/
*.log
*.log.*
*.pid
*.seed
*.pid.lock
.pids

# -----------------------------------------------------------------------------
# Test & Coverage Reports
# -----------------------------------------------------------------------------
coverage/
.nyc_output/
test-results/
playwright-report/
playwright/.cache/

# -----------------------------------------------------------------------------
# IDE & Editor
# -----------------------------------------------------------------------------
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# OS Generated
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# -----------------------------------------------------------------------------
# Misc Build Artifacts
# -----------------------------------------------------------------------------
*.tgz
*.tar.gz
*.zip
