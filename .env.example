# =============================================================================
# openNBA — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit the .env file to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NODE_ENV=development               # development | production | test
DATA_MODE=MOCK                     # MOCK | LIVE — controls which data provider is used

# -----------------------------------------------------------------------------
# Next.js (apps/web)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000   # Public base URL for the web app

# Auth.js / NextAuth (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=                   # Minimum 32 characters; required in production
NEXTAUTH_URL=http://localhost:3000 # Must match the deployed URL in production

# -----------------------------------------------------------------------------
# Database (Supabase / Neon / local PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL=                      # postgresql://user:password@host:5432/opennba
DIRECT_URL=                        # Direct connection URL (used by Drizzle for migrations)

# Supabase-specific (leave blank if using Neon or self-hosted Postgres)
SUPABASE_URL=                      # https://<project>.supabase.co
SUPABASE_ANON_KEY=                 # Supabase anon/public key (safe to expose to browser)
SUPABASE_SERVICE_ROLE_KEY=         # Supabase service-role key (server-side only) 🔒

# -----------------------------------------------------------------------------
# Agent Service (services/agent — Python FastAPI)
# -----------------------------------------------------------------------------
AGENT_SERVICE_URL=http://localhost:8001    # Internal URL for the FastAPI agent service
AGENT_SERVICE_API_KEY=                     # Shared secret for BFF → agent-service calls 🔒

# -----------------------------------------------------------------------------
# LLM Providers
# -----------------------------------------------------------------------------
# AWS Bedrock (primary — data stays in your VPC)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=                 # Use IRSA in production; only for local dev 🔒
AWS_SECRET_ACCESS_KEY=             # Use IRSA in production; only for local dev 🔒
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0

# OpenAI (fallback)
OPENAI_API_KEY=                    # sk-... 🔒
OPENAI_MODEL=gpt-4o

# LangSmith (LLM tracing — optional in dev)
LANGCHAIN_API_KEY=                 # ls__... 🔒
LANGCHAIN_TRACING_V2=false         # true | false
LANGCHAIN_PROJECT=opennba-dev

# -----------------------------------------------------------------------------
# Weaviate (vector store)
# -----------------------------------------------------------------------------
WEAVIATE_URL=                      # https://<cluster>.weaviate.network
WEAVIATE_API_KEY=                  # Weaviate cloud API key 🔒

# -----------------------------------------------------------------------------
# Mock Data Seed (only used when DATA_MODE=MOCK)
# -----------------------------------------------------------------------------
NUM_HCPS=500
NUM_MRS=25
HISTORY_MONTHS=18
GAP_RATE=0.35                      # Fraction of HCPs with a 60+ day visit gap

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=info                     # debug | info | warn | error
