{
  "name": "open-nba",
  "services": {
    "web": {
      "root": "apps/web",
      "framework": "nextjs",
      "buildCommand": "cd ../.. && pnpm turbo run build --filter=@open-nba/web...",
      "outputDirectory": ".next",
      "installCommand": "cd ../.. && pnpm install --frozen-lockfile"
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": { "service": "web" } }
  ],
  "crons": [
    {
      "path": "/api/v1/cron/feedback-weights",
      "schedule": "0 2 * * 0"
    }
  ]
}
